{
  "name": "notebook-lm-local",
  "version": "0.1.0",
  "private": true,
  "description": "A production-grade local NotebookLM clone — privacy-first AI document chat",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backend": "cd backend && .venv/bin/python main.py",
    "build:backend": "./build_backend.sh",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "package": "npm run build && npm run build:backend && electron-builder",
    "start": "concurrently \"npm run backend\" \"npm run dev\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "vite": "^6.3.0",
    "vitest": "^3.2.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.notebooklm.local",
    "productName": "NotebookLM Local",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend-dist",
        "to": "backend-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
